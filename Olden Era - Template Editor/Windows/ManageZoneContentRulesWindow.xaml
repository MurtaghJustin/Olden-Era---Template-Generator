<Window x:Class="Olden_Era___Template_Editor.ManageZoneContentRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Rules"
        Width="420"
        Height="340"
        MinWidth="360"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="#1A1510"
        Foreground="#E8D5A3"
        FontFamily="Segoe UI"
        FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0F0D09">
                <TextBlock x:Name="TxtWindowTitle"
                           Text="Manage Rules"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕"
                        Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Close"
                        Click="BtnClose_Click"/>
            </Grid>

            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <DockPanel Grid.Row="2" Margin="12" Background="{StaticResource BrushPanel}">
                <TextBlock DockPanel.Dock="Top"
                           x:Name="TxtManagingRulesFor"
                           Text="Managing rules for:"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource BrushText}"/>

                <TextBlock DockPanel.Dock="Top"
                           Text="Currently applied rules"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource BrushTextDim}"/>

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Content="Remove rule"
                            Width="100"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnRemoveRule_Click"/>
                    <Button Content="Add rule"
                            Width="100"
                            Margin="0,0,8,0"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnAddRule_Click"/>
                    <Button Content="Close"
                            Width="84"
                            IsCancel="True"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnClose_Click"/>
                </StackPanel>

                <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                    <ListBox x:Name="LbRules"
                             Margin="6"
                             Background="{StaticResource BrushInput}"
                             Foreground="{StaticResource BrushText}"
                             BorderBrush="{StaticResource BrushBorder}"/>
                </Border>
            </DockPanel>
        </Grid>
    </Border>
</Window>
