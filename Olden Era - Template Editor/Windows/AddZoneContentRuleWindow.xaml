<Window x:Class="Olden_Era___Template_Editor.AddZoneContentRuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add rule"
    Width="460"
    Height="320"
    MinWidth="420"
    MinHeight="300"
        WindowStartupLocation="CenterOwner"
    ResizeMode="CanMinimize"
        WindowStyle="None"
        Background="#1A1510"
        Foreground="#E8D5A3"
        FontFamily="Segoe UI"
        FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#0F0D09">
                <TextBlock x:Name="TxtWindowTitle"
                           Text="Add rule"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕"
                        Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Close"
                        Click="BtnClose_Click"/>
            </Grid>

            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <Grid Grid.Row="2" Margin="12" Background="{StaticResource BrushPanel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,10,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Rule"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource BrushText}"/>
                    <ComboBox x:Name="CmbRuleType"
                              Grid.Column="1"
                              Height="30"
                              Background="{StaticResource BrushInput}"
                              Foreground="{StaticResource BrushText}"
                              BorderBrush="{StaticResource BrushBorder}"
                              SelectionChanged="CmbRuleType_SelectionChanged"/>
                </Grid>

                <Border Grid.Row="1"
                        x:Name="PnlDistance"
                        Margin="0,0,0,10"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BrushBorder}"
                        Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtDistanceLabel"
                                   Grid.Column="0"
                                   Text="Distance"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushText}"/>
                        <ComboBox x:Name="CmbDistance"
                                  Grid.Column="1"
                                  Height="30"
                                  Background="{StaticResource BrushInput}"
                                  Foreground="{StaticResource BrushText}"
                                  BorderBrush="{StaticResource BrushBorder}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        x:Name="PnlGuarded"
                        Margin="0,0,0,10"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BrushBorder}"
                        Padding="8"
                        Visibility="Collapsed">
                    <CheckBox x:Name="ChkGuarded"
                              Content="Guarded"
                              IsChecked="True"
                              Foreground="{StaticResource BrushText}"/>
                </Border>

                <Border Grid.Row="3"
                        x:Name="PnlVariant"
                        Margin="0,0,0,10"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BrushBorder}"
                        Padding="8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="TxtVariantContext"
                                   Text="Parent content:"
                                   Margin="0,0,0,6"
                                   Foreground="{StaticResource BrushTextDim}"/>
                        <ComboBox x:Name="CmbVariant"
                                  Height="30"
                                  Background="{StaticResource BrushInput}"
                                  Foreground="{StaticResource BrushText}"
                                  BorderBrush="{StaticResource BrushBorder}"/>
                        <TextBlock x:Name="TxtVariantEmpty"
                                   Margin="0,8,0,0"
                                   Text="No known variants for this content item."
                                   Foreground="{StaticResource BrushTextDim}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                    <Button Content="Cancel"
                            Width="84"
                            Margin="0,0,8,0"
                            IsCancel="True"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnClose_Click"/>
                    <Button Content="Add"
                            Width="84"
                            IsDefault="True"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnAdd_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
