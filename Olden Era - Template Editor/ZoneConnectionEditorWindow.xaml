<Window x:Class="Olden_Era___Template_Editor.ZoneConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone Connection Editor"
        Width="1050" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="#1A1510"
        Foreground="#E8D5A3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/MedievalTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>    <!-- custom title bar -->
                <RowDefinition Height="1"/>     <!-- gold divider -->
                <RowDefinition Height="Auto"/>  <!-- editor toolbar -->
                <RowDefinition Height="*"/>     <!-- canvas + property panel -->
                <RowDefinition Height="Auto"/>  <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="#0F0D09">
                <TextBlock Text="Zone Connection Editor"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Close" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ═══ TOOLBAR ══════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="#221E15" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAddMode" Content="+ Add Connection"
                            Margin="0,0,8,0" Click="BtnAddMode_Click"
                            Style="{StaticResource ToolbarButton}" TabIndex="0"
                            ToolTip="Drag from one zone to another to create a new Direct connection"/>
                    <Button Content="↺  Reset to Generated"
                            Click="BtnReset_Click"
                            Style="{StaticResource ToolbarButton}" TabIndex="1"
                            ToolTip="Restore the auto-generated connection set — all manual edits will be discarded"/>
                </StackPanel>
            </Border>

            <!-- ═══ MAIN CONTENT ═════════════════════════════════════════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="3*" MinWidth="230"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Canvas area ────────────────────────────────────────── -->
                <Grid Grid.Column="0">
                    <Canvas x:Name="ZoneCanvas"
                            Background="#1C1610"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                            ClipToBounds="True"/>
                </Grid>

                <!-- ─── Property panel ─────────────────────────────────────── -->
                <Border Grid.Column="1" Background="#221E15"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="PnlProperties" Visibility="Collapsed" Margin="10,8">

                            <!-- Header + Advanced toggle (matches MainWindow pattern) -->
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Text="CONNECTION PROPERTIES"
                                           Style="{StaticResource SectionHeader}"
                                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkPropAdvanced" Content="Advanced"
                                          DockPanel.Dock="Right" VerticalAlignment="Center"
                                          FontSize="11" Margin="12,0,0,0"
                                          Checked="ChkPropAdvanced_Changed"
                                          Unchecked="ChkPropAdvanced_Changed"/>
                            </DockPanel>

                            <!-- Connection Type -->
                            <TextBlock Text="Connection Type" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbConnectionType" TabIndex="103"
                                      SelectionChanged="CmbConnectionType_SelectionChanged"/>

                            <!-- Guard Strength -->
                            <TextBlock Text="Guard Strength" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbGuardValue" Width="130" TabIndex="104"
                                          SelectionChanged="CmbGuardValue_SelectionChanged"
                                          ToolTip="Guard strength preset; tier inferred from connected zones"/>
                                <TextBox x:Name="TxtPropGuardValueCustom" Width="65" Margin="4,0,0,0"
                                         TabIndex="104" Visibility="Collapsed"
                                         Style="{StaticResource HintTextBox}" Tag="value"
                                         TextChanged="TxtPropGuardValueCustom_TextChanged"
                                         ToolTip="Custom guard value (integer)"/>
                            </StackPanel>

                            <!-- Weekly Growth -->
                            <TextBlock Text="Weekly Growth" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbGuardWeeklyIncrement" Width="130" TabIndex="105"
                                          SelectionChanged="CmbGuardWeeklyIncrement_SelectionChanged"/>
                                <TextBox x:Name="TxtPropIncrementCustom" Width="65" Margin="4,0,0,0"
                                         TabIndex="105" Visibility="Collapsed"
                                         Style="{StaticResource HintTextBox}" Tag="0.15"
                                         TextChanged="TxtPropIncrementCustom_TextChanged"/>
                            </StackPanel>

                            <!-- Guard Zone (only the two connected zones) -->
                            <TextBlock Text="Guard Zone" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <ComboBox x:Name="CmbGuardZone" TabIndex="106"
                                      SelectionChanged="CmbGuardZone_SelectionChanged"
                                      ToolTip="Zone that provides the guard army"/>

                            <!-- Advanced fields (hidden until Advanced is checked) -->
                            <StackPanel x:Name="PnlPropsAdvanced" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock Text="Guard Match Group"
                                           Foreground="{StaticResource BrushTextDim}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtGuardMatchGroup" TabIndex="107"
                                         TextChanged="TxtGuardMatchGroup_TextChanged"/>

                                <CheckBox x:Name="ChkGuardEscape" Content="Guards can flee"
                                          Margin="0,8,0,0" TabIndex="108"
                                          Checked="ChkGuardEscape_Changed"
                                          Unchecked="ChkGuardEscape_Changed"/>
                                <TextBlock Text="Defeated guards may retreat instead of dying"
                                           Foreground="{StaticResource BrushTextDim}" FontSize="10"
                                           FontStyle="Italic" Margin="0,2,0,0"/>

                                <CheckBox x:Name="ChkSimTurnSquad" Content="Sim turn squad"
                                          Margin="0,6,0,0" TabIndex="109"
                                          Checked="ChkSimTurnSquad_Changed"
                                          Unchecked="ChkSimTurnSquad_Changed"/>
                                <TextBlock Text="Simulates simultaneous turns at this connection"
                                           Foreground="{StaticResource BrushTextDim}" FontSize="10"
                                           FontStyle="Italic" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Separator Margin="0,10,0,8" Background="{StaticResource BrushBorder}"/>

                            <Button x:Name="BtnDeleteConnection"
                                    Content="🗑  Delete Connection"
                                    Click="BtnDeleteConnection_Click"
                                    Style="{StaticResource ToolbarButton}"
                                    Foreground="{StaticResource BrushError}"
                                    TabIndex="110"
                                    ToolTip="Remove this connection (Delete key)"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ═══ STATUS BAR ═══════════════════════════════════════════════ -->
            <Border Grid.Row="4" Background="#1A1510"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="8,3">
                <TextBlock x:Name="TxtStatus"
                           Foreground="{StaticResource BrushTextDim}"
                           FontSize="11" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
