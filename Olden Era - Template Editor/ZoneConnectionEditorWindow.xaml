<Window x:Class="Olden_Era___Template_Editor.ZoneConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone Connection Editor"
        Width="1050" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="#1A1510"
        Foreground="#E8D5A3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/MedievalTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>    <!-- custom title bar -->
                <RowDefinition Height="1"/>     <!-- gold divider -->
                <RowDefinition Height="Auto"/>  <!-- editor toolbar -->
                <RowDefinition Height="*"/>     <!-- canvas + property panel -->
                <RowDefinition Height="Auto"/>  <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="#0F0D09">
                <TextBlock Text="Zone Connection Editor"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Close" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ═══ TOOLBAR ══════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="#221E15" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAddMode" Content="+ Add Connection"
                            Margin="0,0,8,0" Click="BtnAddMode_Click"
                            Style="{StaticResource ToolbarButton}" TabIndex="0"
                            ToolTip="Enter add-connection mode: click a source zone, then a destination zone"/>
                    <Button Content="↺  Reset to Generated"
                            Click="BtnReset_Click"
                            Style="{StaticResource ToolbarButton}" TabIndex="1"
                            ToolTip="Restore the auto-generated connection set — all manual edits will be discarded"/>
                </StackPanel>
            </Border>

            <!-- ═══ MAIN CONTENT ═════════════════════════════════════════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="3*" MinWidth="230"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Canvas area ────────────────────────────────────────── -->
                <Grid Grid.Column="0">
                    <Canvas x:Name="ZoneCanvas"
                            Background="#1C1610"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            ClipToBounds="True"/>

                    <!-- Add-connection confirmation panel (overlaid at top of canvas) -->
                    <Border x:Name="PnlAddConfirm" Visibility="Collapsed"
                            VerticalAlignment="Top" Panel.ZIndex="10"
                            Background="#2C2419"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Vertical" Margin="8,5,8,6">
                            <!-- Row 1: header + primary fields -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="TxtAddFromTo" VerticalAlignment="Center"
                                           Foreground="{StaticResource BrushText}" FontSize="12"
                                           Margin="0,0,12,0"/>
                                <Label Content="Name:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtAddName" Width="100" Margin="0,0,8,0" TabIndex="20"/>
                                <Label Content="Type:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <ComboBox x:Name="CmbAddType" Width="90" Margin="0,0,8,0" TabIndex="21"/>
                                <Label Content="Guard Value:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtAddGuardValue" Width="70" Margin="0,0,8,0" TabIndex="22"/>
                                <Button Content="Add" Click="BtnAddConfirm_Click" Margin="0,0,4,0"
                                        Style="{StaticResource ToolbarButton}" TabIndex="23"/>
                                <Button Content="Cancel" Click="BtnAddCancel_Click"
                                        Style="{StaticResource ToolbarButton}" TabIndex="24"/>
                            </StackPanel>
                            <!-- Row 2: extra fields -->
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Guard Zone:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtAddGuardZone" Width="90" Margin="0,0,8,0" TabIndex="25"
                                         Style="{StaticResource HintTextBox}"
                                         ToolTip="Zone that provides the guard army (defaults to the From zone)"/>
                                <Label Content="Guard Match Group:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtAddGuardMatchGroup" Width="130" Margin="0,0,8,0" TabIndex="26"
                                         Style="{StaticResource HintTextBox}"
                                         Tag="e.g. tourney_guard_A_B"
                                         ToolTip="Match group key for synchronising guard levels across connections"/>
                                <Label Content="Weekly Increment:" Padding="0,0,4,0" VerticalAlignment="Center" FontSize="12"/>
                                <TextBox x:Name="TxtAddGuardWeeklyIncrement" Width="60" Margin="0,0,8,0" TabIndex="27"
                                         Style="{StaticResource HintTextBox}" Tag="0.15"
                                         ToolTip="Guard value added each week (decimal). Defaults to 0.15."/>
                                <CheckBox x:Name="ChkAddSimTurnSquad" Content="Sim Turn Squad" TabIndex="28"
                                          VerticalAlignment="Center" Margin="0,0,0,0"
                                          ToolTip="Simulate an extra squad each turn at this connection"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── Property panel ─────────────────────────────────────── -->
                <Border Grid.Column="1" Background="#221E15"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="PnlProperties" Visibility="Collapsed" Margin="10,8">

                            <TextBlock Text="CONNECTION PROPERTIES"
                                       Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                            <!-- From / To (read-only) -->
                            <TextBlock Text="From" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtFromZone" IsReadOnly="True"
                                     Foreground="{StaticResource BrushTextDim}"
                                     Background="#1C1610" TabIndex="100"/>

                            <TextBlock Text="To" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtToZone" IsReadOnly="True"
                                     Foreground="{StaticResource BrushTextDim}"
                                     Background="#1C1610" TabIndex="101"/>

                            <!-- Editable fields -->
                            <TextBlock Text="Name (optional)" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtConnectionName" TabIndex="102"
                                     TextChanged="TxtConnectionName_TextChanged"/>

                            <TextBlock Text="Connection Type" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <ComboBox x:Name="CmbConnectionType" TabIndex="103"
                                      SelectionChanged="CmbConnectionType_SelectionChanged"/>

                            <TextBlock Text="Guard Value" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtGuardValue" TabIndex="104"
                                     TextChanged="TxtGuardValue_TextChanged"/>

                            <TextBlock Text="Guard Weekly Increment"
                                       Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtGuardWeeklyIncrement" TabIndex="105"
                                     TextChanged="TxtGuardWeeklyIncrement_TextChanged"/>

                            <TextBlock Text="Guard Zone" Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtGuardZone" TabIndex="106"
                                     TextChanged="TxtGuardZone_TextChanged"/>

                            <TextBlock Text="Guard Match Group"
                                       Foreground="{StaticResource BrushTextDim}"
                                       FontSize="11" Margin="0,6,0,2"/>
                            <TextBox x:Name="TxtGuardMatchGroup" TabIndex="107"
                                     TextChanged="TxtGuardMatchGroup_TextChanged"/>

                            <CheckBox x:Name="ChkGuardEscape" Content="Guard Escape"
                                      Margin="0,8,0,0" TabIndex="108"
                                      Checked="ChkGuardEscape_Changed"
                                      Unchecked="ChkGuardEscape_Changed"/>

                            <CheckBox x:Name="ChkSimTurnSquad" Content="Sim Turn Squad"
                                      Margin="0,6,0,0" TabIndex="109"
                                      Checked="ChkSimTurnSquad_Changed"
                                      Unchecked="ChkSimTurnSquad_Changed"/>

                            <Separator Margin="0,10,0,8" Background="{StaticResource BrushBorder}"/>

                            <Button x:Name="BtnDeleteConnection"
                                    Content="🗑  Delete Connection"
                                    Click="BtnDeleteConnection_Click"
                                    Style="{StaticResource ToolbarButton}"
                                    Foreground="{StaticResource BrushError}"
                                    TabIndex="110"
                                    ToolTip="Remove this connection (Delete key)"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ═══ STATUS BAR ═══════════════════════════════════════════════ -->
            <Border Grid.Row="4" Background="#1A1510"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                    Padding="8,3">
                <TextBlock x:Name="TxtStatus"
                           Foreground="{StaticResource BrushTextDim}"
                           FontSize="11" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
