                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="•"
                                               Foreground="{Binding Foreground}"
                                               FontSize="12"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                        
                        <Border Grid.Row="4"
                        BorderThickness="2"
                        CornerRadius="4"
                        BorderBrush="{StaticResource BrushBorder}"
                        Background="#1A1410">
                            <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"> 
                                <Label x:Name="lblNoPreview" Visibility="Collapsed" FontSize="172"></Label>
                                <Image x:Name="ImgPreview"
                                Stretch="Uniform"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                        </Border>

                <CheckBox Grid.Row="8"
                          x:Name="ChkSavePreviewImage"
                          Content="Show preview"
                          IsChecked="True"
                          Visibility="Visible"
                          Foreground="{StaticResource BrushText}"
                          HorizontalAlignment="Left" Click="ChkSavePreviewImage_Click" />

                <TextBlock Grid.Row="6"
                           x:Name="TxtOutdatedWarning"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Hidden"
                           HorizontalAlignment="Stretch" TextAlignment="Center"
                           Text="⚠️ Settings have changed — generate a new template before saving to reflect the latest changes."/>

                <Button Grid.Row="10"
                        x:Name="BtnSaveGenerated"
                        Content="💾  Save Template"
                        Style="{StaticResource GenerateButton}"
                        Visibility="Visible"
                        IsEnabled="False"
                        Click="BtnSaveGenerated_Click"/>
            </Grid>

        </Grid>

                    <!-- Hidden combos required by code-behind -->
        <ComboBox Grid.Row="4" x:Name="CmbGameMode" Visibility="Collapsed"/>
        <TextBlock Grid.Row="4" x:Name="TxtAppTitle" Visibility="Collapsed"/>



            </Grid>  <!-- end page content grid -->
        </Grid>      <!-- end outer row grid -->
    </Border>        <!-- end window frame border -->
</Window>
